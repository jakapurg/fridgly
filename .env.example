# Copy to `.env` and adjust for your machine.
# `.env` is git-ignored; this example is committed as the source of truth.

# Postgres connection string (matches docker-compose.yml).
DATABASE_URL=postgres://fridgly:fridgly@localhost:5433/fridgly

# Address the HTTP server binds to.
BIND_ADDR=0.0.0.0:3000

# Connection pool size.
DB_MAX_CONNECTIONS=5

# Directory served at /static (relative to the working directory).
STATIC_DIR=crates/fridgly-web/static

# Anthropic API key for AI meal suggestions. When unset, the Meal ideas screen
# shows a "not set up yet" message and everything else keeps working.
# ANTHROPIC_API_KEY=sk-ant-...
# Claude model used for meal suggestions (defaults to claude-opus-4-8).
# ANTHROPIC_MODEL=claude-opus-4-8

# Log filter (see tracing-subscriber EnvFilter syntax).
RUST_LOG=info,fridgly_web=debug,tower_http=info
